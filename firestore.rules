rules_version = '2';

// POC rules — OPEN access. This app uses notification-OTP (no Firebase Auth),
// so request.auth is null; signed-in checks would deny all. Lock these down
// (per-user ownership + Firebase Auth) before any production use.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
